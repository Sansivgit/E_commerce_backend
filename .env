# Backend environment (single file). Loaded from app.js / server.js via dotenv.

PORT=5000
NODE_ENV=development

# --- Public URLs (no trailing slashes) ---
# This API (Express) — startup log and anything that needs the backend base URL.
API_URL=http://localhost:5000

# Browser origins for CORS / Socket.IO (used when CLIENT_URL below is unset).
FRONTEND_URL=http://localhost:8080
ADMIN_URL=http://localhost:5174
# Optional extra dev origins (comma-separated), e.g. alternate Vite storefront ports.
CORS_EXTRA_ORIGINS=http://localhost:5173

# Optional: set a single comma-separated list to override FRONTEND_/ADMIN_/CORS_EXTRA_* for CORS only.
# CLIENT_URL=http://localhost:8080,http://localhost:5174

