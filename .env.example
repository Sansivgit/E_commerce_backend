# Gmail SMTP — error 535 means Google rejected login. Fix:
# 1) Turn on 2-Step Verification for the Gmail account
# 2) Create an App Password: Google Account → Security → App passwords
# 3) SMTP_USER must be that exact Gmail address. Paste the 16-char App Password into SMTP_PASS (spaces optional).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=1999santhoshsivam@gmail.com
SMTP_PASS=jdzs ckik jddk lywq
SMTP_FROM=1999santhoshsivam@gmail.com

# Frontend URL used in password-reset emails (first origin if comma-separated)
CLIENT_URL=http://localhost:8080
APP_NAME=VOLT
